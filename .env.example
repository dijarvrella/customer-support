# Database (Neon PostgreSQL - create free at https://neon.tech)
# Use the connection string from the Neon dashboard (not "placeholder" or user:password@host).
# With the repo linked to Vercel: `vercel env pull .env.local` (uses Development env; add --environment=production if needed).
# `.env` and `.env.local` are gitignored — never commit them.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Microsoft Entra ID (Azure AD) - Optional for SSO
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Slack Integration - Optional
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""
SLACK_CHANNEL_ID=""

# Email (Resend) — optional; without RESEND_API_KEY, notification emails are skipped
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""

# If Entra manager/CISO cannot be resolved for an approval-category ticket, create
# one pending approval for this mailbox (e.g. staging / break-glass).
FALLBACK_APPROVER_EMAIL=""
# FALLBACK_APPROVER_NAME="IT Approvals"
